                        "type": "string",
                        "format": "email"
                    },
                    "password": {
                        "type": "string"
                    },
                    "full_name": {
                        "type": "string"
                    }
                },
                "required": [
                    "email",
                    "full_name",
                    "password"
                ]
            },
            "AdminSignupResponse": {
                "type": "object",
                "properties": {
                    "message": {
                        "type": "string"
                    },
                    "admin": {
                        "$ref": "#/components/schemas/AdminSignupAdmin"
                    }
                },
                "required": [
                    "admin",
                    "message"
                ]
            },
            "Company": {
                "type": "object",
