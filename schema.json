                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/AdminLoginRequest"
                            }
                        }
                    },
                    "required": true
                },
                "security": [
                    {
                        "JWTAuth": []
                    },
                    {}
                ],
